# {{ cookiecutter.source_name }} Configuration
# Copy this file to .env and fill in your actual values.
# Variable names follow the tap's setting keys; run `{{ cookiecutter.tap_id }} --about` for the
# authoritative list.

{% if cookiecutter.auth_method in ("OAuth2", "JWT") -%}
# Required: OAuth client ID for the {{ cookiecutter.source_name }} OAuth app
{{ cookiecutter.tap_id.upper().replace('-', '_') }}_CLIENT_ID=your_client_id_here

# Required: OAuth client secret for the {{ cookiecutter.source_name }} OAuth app
{{ cookiecutter.tap_id.upper().replace('-', '_') }}_CLIENT_SECRET=your_client_secret_here

# Optional: OAuth refresh token (if your flow uses one)
{{ cookiecutter.tap_id.upper().replace('-', '_') }}_REFRESH_TOKEN=your_refresh_token_here
{% elif cookiecutter.auth_method == "Basic Auth" -%}
# Required: {{ cookiecutter.source_name }} username
{{ cookiecutter.tap_id.upper().replace('-', '_') }}_USERNAME=your_username_here

# Required: {{ cookiecutter.source_name }} password
{{ cookiecutter.tap_id.upper().replace('-', '_') }}_PASSWORD=your_password_here
{% else -%}
# Required: API key used to authenticate against {{ cookiecutter.source_name }}
{{ cookiecutter.tap_id.upper().replace('-', '_') }}_API_KEY=your_api_key_here
{% endif %}
# Optional: The earliest record date to sync (ISO-8601)
{{ cookiecutter.tap_id.upper().replace('-', '_') }}_START_DATE=2023-01-01T00:00:00Z

# Optional: API base URL (defaults to {{ cookiecutter.api_base_url }})
{{ cookiecutter.tap_id.upper().replace('-', '_') }}_API_URL={{ cookiecutter.api_base_url }}
